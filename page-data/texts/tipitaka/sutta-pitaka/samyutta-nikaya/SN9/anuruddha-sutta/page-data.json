type":"text","value":"\nIt’s the abode of lordly gods, "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nthe glorious host of Thirty!” "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\n"},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\n“Fool, don’t you understand "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nthe saying of the perfected ones: "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nall conditions are impermanent, "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\ntheir nature is to rise and fall; "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nhaving arisen, they cease; "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\ntheir stilling is true bliss. "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\n"},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nPenelope, weaver of the web, "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nnow there are no future lives in the hosts of gods. "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nTransmigration through births is finished, "},{"type":"element","tagName":"br","properties":{},"children":[]},{"type":"text","value":"\nnow there is no further existence.”"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"div","properties":{"style":"text-align:center"},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"element","tagName":"a","properties":{"href":"/texts/tipitaka/sutta-pitaka/samyutta-nikaya/SN9/nagadatta-sutta/